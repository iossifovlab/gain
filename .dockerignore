.git/
.venv/
**/.venv/
**/__pycache__/
**/*.pyc
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/

# JS / Angular build artefacts. node_modules in particular is
# hundreds of MB and is reinstalled inside web_ui's CI image
# from package-lock.json, so it has no business being shipped
# in any docker build context.
**/node_modules/
**/dist/
**/.angular/

# …except the wheels the production backend Dockerfile pulls
# in from `dist/core/` and `dist/web_api/`, produced by the
# root Jenkinsfile parallel block.
!dist/core/gain_core-*.whl
!dist/web_api/gain_web_api-*.whl
# Restore the parent dirs so the un-ignore patterns above can
# actually descend into them. (Docker .dockerignore needs the
# parent dirs to be reachable for negation patterns to work.)
!dist
!dist/core
!dist/web_api

containers/
coverage/
*.tar.gz
*.log
test_results/
data
downloads
import
results
cache
work
temp
.vagrant
