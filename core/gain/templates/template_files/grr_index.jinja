<html>
    <head>
     <meta charset="utf-8">
     <link rel="preconnect" href="https://fonts.googleapis.com">
     <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;800&display=swap" />
     <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block" />
    <style>

      body {
        margin: 0;
      }

      {% include "base_styles.jinja" %}

      td, th {
        padding: 5px;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      #search-container {
        margin-top: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        position: sticky;
        top: 0;
        z-index: 2;
        background-color: white;
        height: 70px;
      }

      #type-label {
        color: #5b778c;
      }

      #type-filter {
        border: 1px solid #85a2b9;
        height: 40px;
        border-radius: 5px;
        font-size: 18px;
        padding-left: 10px;
        background: white;
      }

      #type-filter:hover {
        cursor: pointer;
      }

      #search-field {
        width: 40%;
        border: 1px solid #85a2b9;
        height: 40px;
        border-radius: 5px;
        font-size: 18px;
        padding: 0 10px;
      }

      input::placeholder {
        color: #ababab;
      }

      #type-filter:focus-visible,
      #search-field:focus-visible,
      #type-filter:focus,
      #search-field:focus {
        outline-color: #85a2b9;
      }

      .search-info {
        text-align: center;
        font-size: 0.9em;
        color: #5b778c;
        word-break: break-word;
        margin: 0 10%;
      }

      .loading,
      .searching {
        text-align: center;
        font-size: larger;
      }

      .pageButton {
        border: none;
        background: none;
        color: #24699E;
        cursor: pointer;
        padding: 3px;
        margin: 0 3px;
      }

      .pageButton.active {
        color: #1a2835;
        cursor: default;
      }

      .pageButton.hide {
        display: none;
      }

      #status,
      #status-error {
        margin-left: 10%;
        margin-top: 8px;
        font-size: 0.875em;
        color: #5b778c;
      }

      #status-error {
        color: #d74b59;
        text-align: center;
      }

      #table-wrapper {
        margin: 10px 10%;
      }

      #resource-table {
        border: 1px solid #cfd8df;
        width: 100%;
        box-sizing: border-box;
        table-layout: fixed;
        contain: layout style;
      }

      .version-cell {
        width: 5%;
      }

      .size-cell,
      .type-cell {
        width: 10%;
      }

      .id-wrapper {
        display: flex;
        gap: 10px;
        align-items: center;
      }

      .id-cell {
        min-width: 50%;
        width: 50%;
      }

      .copy-icon {
        font-size: 20px;
        color: #B9D3E7;
      }

      .copy-icon:hover {
        cursor: pointer;
        color: #85A2B9;
      }

      #nav-about {
        margin-left: auto;
      }

      #id-col-header,
      #type-col-header,
      #version-col-header,
      #size-col-header,
      #summary-col-header {
        cursor: pointer;
        user-select: none;
      }

      #id-sort-indicator,
      #type-sort-indicator,
      #version-sort-indicator,
      #size-sort-indicator,
      #summary-sort-indicator {
        margin-left: 2px;
        font-size: 18px;
        vertical-align: middle;
        color: #5b778c;
      }

      #resource-table th {
        position: relative;
        overflow: visible;
      }

      .col-resizer {
        position: absolute;
        right: -3px;
        top: 0;
        height: 100vh;
        width: 6px;
        cursor: col-resize;
        user-select: none;
        z-index: 1;
      }

      .col-resizer::after {
        content: '';
        display: block;
        width: 2px;
        height: 100%;
        margin: 0 auto;
        background: #cfd8df;
        transition: background 0.15s;
      }

      .col-resizer:hover::after,
      .col-resizer.resizing::after {
        background: #85a2b9;
      }

      #col-drag-line {
        position: fixed;
        top: 0;
        left: 0;
        width: 1.5px;
        height: 100vh;
        background: #cfd8df;
        display: none;
        pointer-events: none;
        will-change: transform;
      }
    </style>
 </head>
{% include "grr_scripts.jinja" %}
 <body>
     {% if has_about %}
     <nav id="page-header">
       <a id="nav-about" href="about.html">About</a>
     </nav>
     {% endif %}
     <div id="section-resources">
        <p class="loading">Loading search</p>
        <div id="search-container" style="display: none;">
          <span id="type-label">Resource type</span>
          <div id="type-cell">
            <select id="type-filter">
                <option value="all">All</option>
            </select>
          </div>
          <input type="text" id="search-field" placeholder="Search">
        </div>
        <div class="search-info">
          <div>
            use AND to perform 'and',
            use OR to perform 'or',
            use spaces to separate strings,
            surround strings in "" to use spaces inside the string
          </div>
          The search uses
          <a
            href="https://sqlite.org/fts5.html#full_text_query_syntax"
            target="_blank">
            SQLite's FTS syntax.</a>
        </div>
        <p id="status-error"></p>
        <div id="status"></div>
        <div id="table-wrapper">
        <table id="resource-table" class="contents">
          <colgroup>
            <col style="width: 10%"><col style="width: 50%"><col style="width: 5%"><col style="width: 10%"><col style="width: 25%">
          </colgroup>
          <thead>
            <tr>
              <th class="nowrap type-cell" id="type-col-header">Type<span id="type-sort-indicator" class="material-symbols-outlined">unfold_more</span><div class="col-resizer"></div></th>
              <th class="nowrap id-cell" id="id-col-header">ID<span id="id-sort-indicator" class="material-symbols-outlined">unfold_more</span><div class="col-resizer"></div></th>
              <th class="nowrap version-cell" id="version-col-header">Version<span id="version-sort-indicator" class="material-symbols-outlined">unfold_more</span><div class="col-resizer"></div></th>
              <th
                class="nowrap size-cell"
                title="Total size"
                id="size-col-header"
              >Total size<span id="size-sort-indicator" class="material-symbols-outlined">unfold_more</span><div class="col-resizer"></div></th>
              <th class="nowrap" id="summary-col-header">Summary<span id="summary-sort-indicator" class="material-symbols-outlined">unfold_more</span></th>
            </tr>
          </thead>
          <tbody>
            {%- for key, value in data.items() recursive%}
            <tr id="{{value['res_full_id']}}">
              <td
                class="nowrap type-cell"
                title="{{value['type']}}"
              >{{value['type']}}</td>
              <td class="id-cell" title="{{key}}">
                <div class="id-wrapper">
                  <a class="nowrap" href='{{key}}/index.html'>{{key}}</a>
                  <span class="material-symbols-outlined copy-icon {{key}}">content_copy</span>
                </div>
              </td>
              <td class="nowrap version-cell">{{value['res_version']}}</td>
              <td class="nowrap size-cell">{{value['res_size']}}</td>
              <td
                class="nowrap"
                title="{{value['res_summary']|e}}"
              >{{value['res_summary']}}</td>
              </tr>
            {%- endfor %}
          </tbody>
        </table>
        </div>
        <p class="searching" style="display: none;">Searching</p>
     </div>
     <div class="pagination"></div>
     </div>
     <script>
       (function() {
         var table = document.getElementById('resource-table');
         if (!table) return;
         var h = table.offsetHeight + 'px';
         table.querySelectorAll('.col-resizer').forEach(function(r) { r.style.height = h; });
       })();
     </script>
 </body>
</html>
