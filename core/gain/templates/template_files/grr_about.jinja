<html>
    <head>
     <meta charset="utf-8">
     <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
      }

      * {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      }

      body {
        margin: 0;
      }

      {% include "base_styles.jinja" %}

      td, th {
        padding: 5px;
        max-width: 100px;
      }

      #search-container {
        margin-top: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        position: sticky;
        top: 0;
        z-index: 1;
        background-color: white;
        height: 70px;
      }

      #type-label {
        color: #5b778c;
      }

      #type-filter {
        border: 1px solid #85a2b9;
        height: 40px;
        border-radius: 5px;
        font-size: 18px;
        padding-left: 10px;
        background: white;
      }

      #type-filter:hover {
        cursor: pointer;
      }

      #search-field {
        width: 40%;
        border: 1px solid #85a2b9;
        height: 40px;
        border-radius: 5px;
        font-size: 18px;
        padding: 0 10px;
      }

      input::placeholder {
        color: #ababab;
      }

      #type-filter:focus-visible,
      #search-field:focus-visible,
      #type-filter:focus,
      #search-field:focus {
        outline-color: #85a2b9;
      }

      .nowrap {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .search-info {
        text-align: center;
        font-size: 0.9em;
        color: #5b778c;
        word-break: break-word;
        margin: 0 10%;
      }

      .loading,
      .searching {
        text-align: center;
        font-size: larger;
      }

      .pageButton {
        border: none;
        background: none;
        color: #24699E;
        cursor: pointer;
        padding: 3px;
        margin: 0 3px;
      }

      .pageButton.active {
        color: #1a2835;
        cursor: default;
      }

      .pageButton.hide {
        display: none;
      }

      #status,
      #status-error {
        margin-left: 10%;
        margin-top: 8px;
        font-size: 0.875em;
        color: #5b778c;
      }

      #status-error {
        color: #d74b59;
        text-align: center;
      }

      #resource-table {
        margin: 10px 10%;
        width: 80%;
        border: 1px solid #cfd8df;
      }

      .version-cell {
        width: 5%;
      }

      .size-cell,
      .type-cell {
        width: 10%;
      }

      .id-wrapper {
        display: flex;
        gap: 10px;
        align-items: center;
      }

      .id-cell {
        min-width: 50%;
        width: 50%;
      }

      .copy-icon {
        font-size: 20px;
        color: #B9D3E7;
      }

      .copy-icon:hover {
        cursor: pointer;
        color: #85A2B9;
      }

      #section-about {
        margin: 40px 10%;
        color: #2d3d4a;
        line-height: 1.65;
      }

      #section-about h1 {
        font-size: 1.6em;
        font-weight: 700;
        color: #5b778c;
        margin: 0 0 16px;
      }

      #section-about h2 {
        font-size: 1.1em;
        font-weight: 700;
        color: #5b778c;
        margin: 2em 0 0.5em;
      }

      #section-about p {
        font-size: 0.875em;
        margin: 0 0 0.75em;
      }

      #section-about ul {
        font-size: 0.875em;
        list-style-type: '- ';
        padding-left: 15px;
        margin: 0 0 0.75em;
      }

      #section-about li {
        margin-bottom: 0.4em;
        padding-left: 4px;
      }

      #section-about a {
        text-decoration: underline;
      }

      #nav-about {
        margin-left: auto;
      }
    </style>
 </head>
    <body>
        <nav id="page-header">
          <a href="./">← Back to main page</a>
        </nav>
        <div id="section-about">
        {{about_contents}}
        </div>
    </body>
</html>
