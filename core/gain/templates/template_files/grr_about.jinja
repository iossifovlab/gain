<html>
    <head>
     <meta charset="utf-8">
     <link rel="preconnect" href="https://fonts.googleapis.com">
     <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;800&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
    <style>

      body {
        margin: 0;
      }

      {% include "base_styles.jinja" %}

      #section-about {
        margin: 40px 10%;
        color: #2d3d4a;
        line-height: 1.65;
      }

      #section-about h1 {
        font-size: 1.6em;
        font-weight: 700;
        color: #5b778c;
        margin: 0 0 16px;
      }

      #section-about h2 {
        font-size: 1.1em;
        font-weight: 700;
        color: #5b778c;
        margin: 2em 0 0.5em;
      }

      #section-about p {
        font-size: 0.875em;
        margin: 0 0 0.75em;
      }

      #section-about ul {
        font-size: 0.875em;
        list-style-type: '- ';
        padding-left: 15px;
        margin: 0 0 0.75em;
      }

      #section-about li {
        margin-bottom: 0.4em;
        padding-left: 4px;
      }

      #section-about a {
        text-decoration: underline;
      }

      #nav-about {
        margin-left: auto;
      }
    </style>
 </head>
    <body>
        <nav id="page-header">
          <a href="./">← Back to main page</a>
        </nav>
        <div id="section-about">
        {{about_contents}}
        </div>
    </body>
</html>
