    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script type="module">
        import sqlite3 from "https://cdn.jsdelivr.net/npm/@sqlite.org/sqlite-wasm@3.51.2-build6/dist/index.mjs";


        const start = async (sqlite3) => {
          const response = await fetch(new URL(`.CONTENTS.sqlite3.gz?v={{ sqlite3_hash }}`, document.baseURI))
          const ds = new DecompressionStream('gzip');
          const decompressedResponse = new Response(response.body.pipeThrough(ds));
          const arrayBuffer = await decompressedResponse.arrayBuffer()
          const p = await sqlite3.wasm.allocFromTypedArray(arrayBuffer)
          const db = new sqlite3.oo1.DB();
          let deserialize_flags = sqlite3.capi.SQLITE_DESERIALIZE_FREEONCLOSE;
          const rc = await sqlite3.capi.sqlite3_deserialize(db.pointer, 'main', p, arrayBuffer.byteLength, arrayBuffer.byteLength, deserialize_flags);
          await db.checkRc(rc);
          window.sqlite3 = db;
          window.sqlite3.query = (sql) => {
            const rows =  window.sqlite3.exec({sql: sql, returnValue: "resultRows"});
            console.log(`Executed query: ${sql}, got ${rows.length} rows`);
            console.log(rows);
            return rows;
          }
          // window.sqlite3.query = (sql) => {
          //  return window.sqlite3.exec({sql: sql, returnValue: "resultRows"})
          //}
        };

        const initializeSQLite = async () => {
          try {
            console.log('Loading and initializing SQLite3 module...');
            const sqlite3 = await sqlite3InitModule();
            console.log('Done initializing.');
            await start(sqlite3);
          } catch (err) {
            console.error('Initialization error:', err.name, err.message);
          }
        };


        function parseSizeToBytes(sizeStr) {
            const units = {
                'B': 1,
                'KB': 1024,
                'MB': 1024 * 1024,
                'GB': 1024 * 1024 * 1024,
                'TB': 1024 * 1024 * 1024 * 1024,
            };
            const match = sizeStr.match(/^([\d.]+)\s*([A-Z]+)$/);
            if (!match) return 0;
            const [, value, unit] = match;
            const multiplier = units[unit] || 1;
            return parseFloat(value) * multiplier;
        }

        const rowData = {}
        $(".contents > tbody > tr").each((index, row) => {
            const id = $(row).attr("id");
            const children = $(row).find("td");
            const sizeStr = children[3].textContent.trim();
            rowData[id] = {
                "type": children[0].textContent.trim(),
                "id": children[1].getElementsByTagName("a")[0].textContent.trim(),
                "version": children[2].textContent.trim(),
                "size": sizeStr,
                "sizeInBytes": parseSizeToBytes(sizeStr),
                "summary": children[4].textContent.trim(),
                "url": $(children[1].getElementsByTagName("a")[0]).attr("href").trim(),
            };
        })
        window.rowData = rowData;

        let sortColumn = 'none'; // 'none' | 'id' | 'type' | 'version' | 'summary'
        let sortOrder = 'none'; // 'none' | 'asc' | 'desc'
        let lastIds = [];

        function sortedIds(ids) {
            if (sortOrder === 'none' || sortColumn === 'none') return ids;
            const sorted = [...ids].sort((a, b) => {
                let aVal, bVal;
                let isNumeric = false;
                if (sortColumn === 'id') {
                    aVal = window.rowData[a].id;
                    bVal = window.rowData[b].id;
                } else if (sortColumn === 'type') {
                    aVal = window.rowData[a].type;
                    bVal = window.rowData[b].type;
                } else if (sortColumn === 'version') {
                    aVal = window.rowData[a].version;
                    bVal = window.rowData[b].version;
                } else if (sortColumn === 'size') {
                    aVal = window.rowData[a].sizeInBytes;
                    bVal = window.rowData[b].sizeInBytes;
                    isNumeric = true;
                } else if (sortColumn === 'summary') {
                    aVal = window.rowData[a].summary;
                    bVal = window.rowData[b].summary;
                }
                if (isNumeric) {
                    return aVal - bVal;
                }
                return aVal.localeCompare(bVal);
            });
            return sortOrder === 'desc' ? sorted.reverse() : sorted;
        }

        function applyRefreshData(ids) {
            lastIds = ids;
            refreshData(sortedIds(ids));
        }

        function UpdateStatus() {
            const status = $(`#status`);
            const statusError = $(`#status-error`);
            if (window.last_error) {
                statusError.show();
                statusError.text(`Query failed due to syntax error, debugging information is in the console.`);
            }
            else {
                statusError.text("");
                statusError.hide();
            }
            status.text(`${window.currentIds.length} resources`);
        }

        function refreshData(ids) {
            // Check both length and order so re-sorting the same set still re-renders.
            if (ids.length === (window.currentIds || []).length
                    && ids.every((id, i) => id === window.currentIds[i])) {
                UpdateStatus();
                return;
            }
            window.currentIds = ids;

            const rows = $(".contents > tbody > tr")
            rows.hide();
            for (const [index, rowId] of ids.entries()) {
                let row = $(rows[index]);
                let rowData = window.rowData[rowId];
                let cells = row.children("td");
                cells[0].textContent = rowData.type;
                cells[1].title = rowData.id;
                $(cells[1]).find("a").attr("href", rowData.url).text(rowData.id);
                $(cells[1]).children("div").children("span")[0].className = `material-symbols-outlined copy-icon ${rowData.id}`;
                cells[2].textContent = rowData.version;
                cells[3].textContent = rowData.size;
                cells[4].textContent = rowData.summary;
                cells[4].title = rowData.summary;
                row.show();
            }

            UpdateStatus();
        }

        window.dbLoaded = new Promise(async (resolve) => {
            await initializeSQLite()
            const all_ids_result = await window.sqlite3.query("SELECT full_id FROM contents;")
            window.all_ids = new Set(all_ids_result.map((row) => row[0]))
            const all_types_result = await window.sqlite3.query("SELECT DISTINCT type FROM contents ORDER BY type ASC;")
            const typeFilter = $("#type-filter");
            for (const row of all_types_result) {
                const type = row[0];
                const option = document.createElement("option");
                option.value = type;
                option.textContent = type;
                typeFilter.append(option);
            }
            applyRefreshData(Array.from(window.all_ids))

            resolve(window.sqlite3)
        });

        $(".loading").hide()

        $("#search-container").show()

        async function doSearch() {
            await window.dbLoaded;
            const searchValue = $("#search-field").val().trim();
            const typeFilter = $("#type-filter").val();
            if (searchValue === "" && typeFilter === "all") {
                window.last_error = null;
                applyRefreshData(Array.from(window.all_ids))
                return;
            }

            $(".searching").show()

            const ids = new Set();

            let query = "";;
            if (searchValue !== "" && typeFilter !== "all") {
                query = `SELECT full_id FROM contents WHERE contents MATCH '${searchValue}' AND type = '${typeFilter}'`
            }
            else if (searchValue !== "") {
                query = `SELECT full_id FROM contents WHERE contents MATCH '${searchValue}'`
            }
            else {
                query = `SELECT full_id FROM contents WHERE type = '${typeFilter}'`
            }

            window.last_error = null;
            try {
                const displayIds = window.sqlite3.query(query).map((row) => row[0]);
                applyRefreshData(displayIds);
            }
            catch (error) {
                window.last_error = error;
                console.error("Error during search:", error);
                applyRefreshData(Array.from(window.all_ids))
            }
            finally {
                $(".searching").hide()
            }
        }

        $("#type-filter").on("change", (e) => {
            doSearch();
        })

        function debounce(func, wait, immediate) {
            var timeout;
            return function() {
                var context = this, args = arguments;
                var later = function() {
                    timeout = null;
                    if (!immediate) func.apply(context, args);
                };
                var callNow = immediate && !timeout;
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
                if (callNow) func.apply(context, args);
            };
        };

        var debouncedSearch = debounce(doSearch, 400, false);

        $("#search-field").on("keydown", (e) => {
          if (e.key === "Enter") {
            doSearch();
          }
          else {
            debouncedSearch();
          }
          // reset all icons
           document.querySelectorAll('.copy-icon').forEach(i => i.textContent = 'content_copy')
        });
        
        $(".copy-icon").on("click", (e) => {
          navigator.clipboard.writeText(e.target.classList[2]).then(
            () => {
              // reset all icons
              document.querySelectorAll('.copy-icon').forEach(i => i.textContent = 'content_copy')
              e.target.textContent = 'check'
              setTimeout(function(){
                e.target.textContent = 'content_copy'
              }, 3000);
            }
          )
        });

        const sortableColumns = {
            'id-col-header': 'id',
            'type-col-header': 'type',
            'version-col-header': 'version',
            'size-col-header': 'size',
            'summary-col-header': 'summary'
        };

        const sortIcons = { none: 'unfold_more', asc: 'arrow_upward', desc: 'arrow_downward' };

        function updateSortIndicators() {
            Object.entries(sortableColumns).forEach(([headerId, colName]) => {
                const indicator = document.getElementById(colName + '-sort-indicator');
                indicator.textContent = sortColumn === colName ? sortIcons[sortOrder] : sortIcons['none'];
            });
        }

        Object.entries(sortableColumns).forEach(([headerId, colName]) => {
            document.getElementById(headerId).addEventListener('click', (e) => {
                if (e.target.closest('.col-resizer')) return;
                if (sortColumn === colName) {
                    sortOrder = sortOrder === 'none' ? 'asc' : sortOrder === 'asc' ? 'desc' : 'none';
                } else {
                    sortColumn = colName;
                    sortOrder = 'asc';
                }
                updateSortIndicators();
                refreshData(sortedIds(lastIds));
            });
        });

    </script>
    <script type="module">
        const table = document.getElementById('resource-table');
        const cols = Array.from(table.querySelectorAll('colgroup col'));
        const ths = Array.from(table.querySelectorAll('thead th'));

        // Proportionally rescale all columns when the wrapper changes size.
        // Col widths start as CSS percentages; the observer only acts once pixel
        // widths have been snapshotted on first drag (colTotal is NaN until then).
        const wrapper = document.getElementById('table-wrapper');
        const wrapperObserver = new ResizeObserver(() => {
          const newWidth = table.clientWidth;
          const colTotal = cols.reduce((s, c) => s + parseInt(c.style.width, 10), 0);
          // Guard < 2px to avoid an infinite loop: writing col widths can itself
          // trigger the observer.
          if (!colTotal || Math.abs(newWidth - colTotal) < 2) return;
          const scale = newWidth / colTotal;
          cols.forEach(c => { c.style.width = Math.round(parseInt(c.style.width, 10) * scale) + 'px'; });
        });
        wrapperObserver.observe(wrapper);

        // A synchronous inline script sets the initial height before first paint;
        // this observer keeps it correct when rows are filtered in/out.
        const resizers = Array.from(table.querySelectorAll('.col-resizer'));
        function updateResizerHeights() {
          const h = table.offsetHeight + 'px';
          resizers.forEach(r => { r.style.height = h; });
        }
        updateResizerHeights();
        const tableObserver = new ResizeObserver(updateResizerHeights);
        tableObserver.observe(table);

        let pixelWidthsInitialized = false;

        const dragLine = document.createElement('div');
        dragLine.id = 'col-drag-line';
        document.body.appendChild(dragLine);

        const MIN_WIDTH = 85;

        ths.forEach((th, i) => {
          const resizer = th.querySelector('.col-resizer');
          if (!resizer) return;

          resizer.addEventListener('mousedown', (e) => {
            // Convert CSS percentage col widths to pixels on first drag so the
            // wrapperObserver and drag deltas work in consistent pixel units.
            if (!pixelWidthsInitialized) {
              ths.forEach((t, idx) => { cols[idx].style.width = t.offsetWidth + 'px'; });
              pixelWidthsInitialized = true;
            }

            const startWidths = cols.map(c => parseInt(c.style.width, 10));
            const startX = e.clientX;

            // Cascade bounds: sum shrinkable space across all cols in each direction.
            let rightRoom = 0;
            for (let j = i + 1; j < cols.length; j++) {
              rightRoom += Math.max(0, startWidths[j] - MIN_WIDTH);
            }
            let leftRoom = 0;
            for (let j = i; j >= 0; j--) {
              leftRoom += Math.max(0, startWidths[j] - MIN_WIDTH);
            }
            const minX = startX - leftRoom;
            const maxX = startX + rightRoom;

            resizer.classList.add('resizing');
            document.body.style.cursor = 'col-resize';
            document.body.style.userSelect = 'none';
            table.style.pointerEvents = 'none';
            const wrapperRect = wrapper.getBoundingClientRect();
            dragLine.style.top = wrapperRect.top + 'px';
            dragLine.style.height = wrapperRect.height + 'px';
            dragLine.style.transform = 'translateX(' + e.clientX + 'px)';
            dragLine.style.display = 'block';

            const onMouseMove = (ev) => {
              dragLine.style.transform = 'translateX(' + Math.min(maxX, Math.max(minX, ev.clientX)) + 'px)';
            };

            const onMouseUp = (ev) => {
              dragLine.style.display = 'none';
              resizer.classList.remove('resizing');
              document.body.style.cursor = '';
              document.body.style.userSelect = '';
              table.style.pointerEvents = '';
              document.removeEventListener('mousemove', onMouseMove);
              document.removeEventListener('mouseup', onMouseUp);

              const delta = Math.min(maxX, Math.max(minX, ev.clientX)) - startX;
              const newWidths = [...startWidths];

              if (delta > 0) {
                // Dragging right: col[i] grows, right cols shrink one by one.
                let toTake = delta;
                for (let j = i + 1; j < cols.length && toTake > 0; j++) {
                  const taken = Math.min(toTake, startWidths[j] - MIN_WIDTH);
                  newWidths[j] = startWidths[j] - taken;
                  toTake -= taken;
                }
                newWidths[i] = startWidths[i] + (delta - toTake);
              } else if (delta < 0) {
                // Dragging left: left cols shrink one by one, col[i+1] grows.
                let toTake = -delta;
                for (let j = i; j >= 0 && toTake > 0; j--) {
                  const taken = Math.min(toTake, startWidths[j] - MIN_WIDTH);
                  newWidths[j] = startWidths[j] - taken;
                  toTake -= taken;
                }
                if (i + 1 < cols.length) {
                  newWidths[i + 1] = startWidths[i + 1] + (-delta - toTake);
                }
              }

              cols.forEach((c, j) => { c.style.width = newWidths[j] + 'px'; });
            };

            // Listeners on document, not the handle, so dragging outside the
            // element doesn't break the interaction.
            document.addEventListener('mousemove', onMouseMove);
            document.addEventListener('mouseup', onMouseUp);
            // Prevent text selection while dragging.
            e.preventDefault();
          });
        });
    </script>
